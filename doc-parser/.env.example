# Redis
REDIS_URL=redis://localhost:6379/0

# 存储策略：local | cloud
STORAGE_TYPE=local

# 本地存储配置（STORAGE_TYPE=local 时生效）
STORAGE_PATH=/data/jobs
SERVICE_BASE_URL=http://localhost:8100

# 云存储配置（STORAGE_TYPE=cloud 时生效）
# MinIO（私有化）
# CLOUD_ENDPOINT=http://minio:9000
# CLOUD_BUCKET=doc-parser
# CLOUD_ACCESS_KEY=minioadmin
# CLOUD_SECRET_KEY=minioadmin

# 阿里云 OSS
# CLOUD_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# CLOUD_BUCKET=my-kb-bucket
# CLOUD_ACCESS_KEY=xxx
# CLOUD_SECRET_KEY=xxx
# CLOUD_REGION=cn-hangzhou

# AWS S3
# CLOUD_BUCKET=my-bucket
# CLOUD_ACCESS_KEY=xxx
# CLOUD_SECRET_KEY=xxx
# CLOUD_REGION=us-east-1

# 预签名 URL 有效期（秒）
CLOUD_URL_EXPIRES=3600

# 文件大小限制（MB）
MAX_FILE_SIZE_MB=200

# Worker 模式（docker-compose 区分 api / worker 用）
WORKER_MODE=false

# PP-StructureV3 模型缓存目录（首次运行自动下载约 300MB 模型）
# 挂载 Docker Volume 可避免重复下载
PADDLE_HOME=/data/paddle_models
# 跳过 paddlex 启动时的模型源网络检查（避免网络慢时卡死）
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
