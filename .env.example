# QueryGenie Server
DASHSCOPE_API_KEY=your-dashscope-api-key
OPENAI_API_KEY=your-openai-compatible-api-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen2.5-7b-instruct-1m
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT_MS=10000

# MySQL / Redis / Elasticsearch
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=genie
MYSQL_USERNAME=root
MYSQL_PASSWORD=123456
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=123456
ELASTICSEARCH_HOST=http://localhost:9200

# 语雀 Open API（解析语雀文档链接时必填）
YUQUE_AUTH_TOKEN=

# 联网搜索配置（多 Provider 可插拔）
# provider 可选值: bocha | baidu | ali-iqs | searxng | oriosearch
APP_WEB_SEARCH_ENABLED=true
APP_WEB_SEARCH_PROVIDER=bocha
APP_WEB_SEARCH_MAX_RESULTS=5

# 博查AI Search API（默认 Provider，https://open.bochaai.com 注册获取）
BOCHA_API_KEY=

# 百度AI搜索（千帆平台，https://console.bce.baidu.com/ai_apaas 注册获取）
BAIDU_AI_SEARCH_API_KEY=

# 阿里云 IQS 通用搜索（https://ipaas.console.aliyun.com 开通）
ALI_IQS_API_KEY=

# SearXNG 自托管（免费，docker run -d -p 8080:8080 searxng/searxng）
SEARXNG_BASE_URL=http://localhost:8080
